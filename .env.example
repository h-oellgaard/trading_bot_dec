# Copy to .env and fill in your values.
# Vars with (default) are optional - fallback used when missing.

# === Required (no fallback) ===
FIRI_API_KEY=
FIRI_SECRET=
FIRI_CLIENT_ID=
# Local: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
# Render/cloud: paste entire JSON content as single line (no GOOGLE_APPLICATION_CREDENTIALS needed)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# === Optional (fallbacks shown) ===
FIRI_BASE_URL=https://api.firi.com
TRAILING_STOP_LOSS_PERCENT=7.0
COOLDOWN_CANDLES=25
PRICE_DECIMALS=2
QUANTITY_DECIMALS=8

# === Firebase logs (ERROR=minimal, WARNING=default, INFO=verbose) ===
# FIREBASE_LOG_LEVEL=WARNING
# Firestore retention cap per pair for prices/EMA collections.
MAX_SERIES_ENTRIES_PER_PAIR=150

# === Settings (from settings/config.py) ===
# Live trading: set true only when ready (real orders on Firi).
TRADING_ENABLED=false
CANDLE_LIMIT=100
STARTUP_CANDLE_LIMIT=200
MIN_FIREBASE_CANDLES=50
# Fixed spend in quote currency per buy (200 DKK for ETH/DKK). Override only if you intend a different size.
BUY_QUOTE_AMOUNT=200
# Used to size base quantity so total quote outlay matches test_trade / Firi fee model (~0.7%).
FIRI_FEE_PERCENT=0.7
SECONDS_PER_CANDLE=3600

# === In trading_config.py (non-sensitive, version-controlled) ===
# TRADING_PAIR, SHORT_EMA_PERIOD, MEDIUM_EMA_PERIOD, LONG_EMA_PERIOD,
# LONG_SMA_FOR_EMA, CANDLE_INTERVAL, POLL_INTERVAL
