#!/bin/sh
# Run tests before push. Blocks push if tests fail.
cd "$(git rev-parse --show-toplevel)" || exit 1
echo ""
echo "========== Running tests before push =========="
echo ""
python -m pytest -vv --tb=long -rA
result=$?
if [ $result -ne 0 ]; then
  echo ""
  echo "=============================================="
  echo "  TESTS FAILED - PUSH ABORTED"
  echo "=============================================="
  echo "  Fix the failing test(s) above and try again."
  echo "  Look for FAILED in the output above."
  echo "=============================================="
  exit 1
fi
echo ""
echo "All tests passed."
exit 0
