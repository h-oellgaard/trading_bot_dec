#!/bin/sh
# Run tests before push. Blocks push if tests fail.
cd "$(git rev-parse --show-toplevel)" || exit 1
echo "Running tests before push..."
python -m pytest
if [ $? -ne 0 ]; then
  echo ""
  echo "Tests failed. Push aborted. Fix the failing tests and try again."
  exit 1
fi
echo "All tests passed."
exit 0
